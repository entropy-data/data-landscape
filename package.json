{
  "name": "data-landscape",
  "private": true,
  "description": "Source for data-landscape.com — interactive landscape of open standards for modern data architecture.",
  "scripts": {
    "dev": "concurrently \"npx @tailwindcss/cli -i ./src/input.css -o ./dist/output.css --watch\" \"serve -l 3000\"",
    "build": "npx @tailwindcss/cli -i ./src/input.css -o ./dist/output.css --minify"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "concurrently": "^9.2.1",
    "serve": "^14.2.6",
    "tailwindcss": "^4.2.1"
  }
}
